{
  "name": "react-example",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node copy-images.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js dist-electron",
    "lint": "tsc --noEmit",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "html2canvas-pro": "^2.0.4",
    "lucide-react": "^0.546.0",
    "modern-screenshot": "^4.7.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.roco.egg.manager",
    "productName": "洛克王国孵蛋数据管理系统",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "001.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "images/**/*"
    ]
  }
}
