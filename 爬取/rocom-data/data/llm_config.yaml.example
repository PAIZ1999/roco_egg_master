# 大模型配置 — 本机开发请复制为 llm_config.yaml 并填入真实值
#
# endpoint: OpenAI 兼容的 API 端点（不含 /chat/completions）
# model:    模型名称
# api_key:  API key
# temperature: 温度参数（越低越确定，0.2~0.7 适合对战决策）
# timeout:   HTTP 请求超时秒数（生成队伍/策略时 prompt 较长，需更大值）
#
# 经验文档存储在 data/llm_experience/<team_name>.json

endpoint: "https://api.deepseek.com/v1"
model: "deepseek-v4-pro"
api_key: "YOUR_DEEPSEEK_API_KEY_HERE"
temperature: 0.3
timeout: 120
